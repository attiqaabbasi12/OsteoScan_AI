# ════════════════════════════════════════════════════
#   OsteoScan AI — .gitignore
# ════════════════════════════════════════════════════

# ── Model Weights (too large for GitHub — store on HF or Drive) ──
backend/model/best_swin_model.pth
*.pth
*.pt
*.ckpt
*.bin

# ── Python ────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environments ──────────────────────────────────────
venv/
env/
.venv/
backend/venv/

# ── Environment Files ─────────────────────────────────────────
.env
backend/.env
frontend/.env.local

# ── Database (generated at runtime) ──────────────────────────
backend/database.db
*.db
*.sqlite

# ── Generated Files (created at runtime) ─────────────────────
backend/static/uploads/
backend/static/heatmaps/
backend/static/reports/

# ── Node / React ──────────────────────────────────────────────
frontend/node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
